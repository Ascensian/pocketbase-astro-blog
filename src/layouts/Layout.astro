---
import Analytics from '@vercel/analytics/astro';

const { title } = Astro.props;
---

<html lang="fr">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <Analytics />
    <title>{title}</title>
    <link
      href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;600;800&display=swap"
      rel="stylesheet"
    />
    <style>
      *,
      *::before,
      *::after {
        box-sizing: border-box;
        margin: 0;
        padding: 0;
      }

      body {
        background: #0a0e13;
        color: #c8ddd6;
        font-family: "JetBrains Mono", monospace;
        min-height: 100vh;
        display: flex;
        flex-direction: column;
      }

      nav {
        background: #0a0e13;
        border-bottom: 0.5px solid #1e2a35;
        padding: 16px 32px;
        display: flex;
        align-items: center;
        justify-content: space-between;
        position: relative;
      }

      .logo {
        font-size: 20px;
        font-weight: 600;
        color: #ffffff;
        text-decoration: none;
        letter-spacing: 0.05em;
      }

      .logo span {
        color: #4a6a7c;
      }

      .nav-links {
        display: flex;
        gap: 24px;
        list-style: none;
      }

      .nav-links a {
        font-size: 11px;
        color: #4a6a7c;
        text-decoration: none;
        letter-spacing: 0.1em;
        text-transform: uppercase;
        transition: color 0.2s;
      }

      .nav-links a:hover {
        color: #00e5a0;
      }

      .burger-btn {
        display: none;
        flex-direction: column;
        gap: 5px;
        background: none;
        border: none;
        cursor: pointer;
        padding: 4px;
      }

      .burger-btn span {
        display: block;
        width: 22px;
        height: 1.5px;
        background: #4a6a7c;
        transition: transform 0.2s, opacity 0.2s;
      }

      .burger-btn.open span:nth-child(1) {
        transform: translateY(6.5px) rotate(45deg);
      }

      .burger-btn.open span:nth-child(2) {
        opacity: 0;
      }

      .burger-btn.open span:nth-child(3) {
        transform: translateY(-6.5px) rotate(-45deg);
      }

      @media (max-width: 540px) {
        .burger-btn {
          display: flex;
        }

        .nav-links {
          display: none;
          position: absolute;
          top: 100%;
          left: 0;
          right: 0;
          background: #0a0e13;
          border-bottom: 0.5px solid #1e2a35;
          flex-direction: column;
          padding: 16px 32px;
          gap: 16px;
          z-index: 100;
        }

        .nav-links.open {
          display: flex;
        }
      }

      main {
        flex: 1;
      }

      footer {
        background: #060a0d;
        border-top: 0.5px solid #1e2a35;
        padding: 10px 32px;
        display: flex;
        align-items: center;
        justify-content: space-between;
      }

      .footer-status,
      .footer-links {
        display: flex;
        align-items: center;
        gap: 16px;
      }

      .status-item {
        font-size: 10px;
        color: #2e4a5a;
        display: flex;
        align-items: center;
        gap: 6px;
      }

      .status-dot {
        width: 5px;
        height: 5px;
        background: #00e5a0;
        border-radius: 50%;
      }

      .divider-v {
        width: 0.5px;
        height: 12px;
        background: #1e2a35;
      }

      @media (max-width: 540px) {
        footer {
          flex-direction: column;
          align-items: stretch;
          padding: 12px 16px;
          gap: 0;
        }

        .footer-status {
          padding-bottom: 10px;
        }

        .footer-links {
          border-top: 0.5px solid #1e2a35;
          padding-top: 10px;
          justify-content: flex-start;
        }
      }

      .live-btn {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        color: #00e5a0 !important;
      }

      .live-dot {
        width: 6px;
        height: 6px;
        background: #00e5a0;
        border-radius: 50%;
        animation: pulse 1.5s infinite;
      }

      @keyframes pulse {
        0% {
          opacity: 1;
        }
        50% {
          opacity: 0.2;
        }
        100% {
          opacity: 1;
        }
      }
    </style>
  </head>
  <body>
    <nav>
      <a class="logo" href="/">Hugo GERARD</a>
      <button class="burger-btn" id="burgerBtn" aria-label="Menu" aria-expanded="false">
        <span></span>
        <span></span>
        <span></span>
      </button>

      <ul class="nav-links" id="navLinks">
        <li><a href="/ressources">Ressources</a></li>
        <li>
          <a href="#" class="live-btn">
            <span class="live-dot"></span>Live system
          </a>
        </li>
      </ul>
    </nav>

    <script>
      const burgerBtn = document.getElementById("burgerBtn");
      const navLinks = document.getElementById("navLinks");

      burgerBtn?.addEventListener("click", () => {
        const isOpen = navLinks?.classList.toggle("open");
        burgerBtn.classList.toggle("open");
        burgerBtn.setAttribute("aria-expanded", String(isOpen));
      });
    </script>

    <main>
      <slot />
    </main>

    <footer>
      <div class="footer-status">
        <div class="status-item">
          <span class="status-dot"></span>PocketBase · Production
        </div>
        <div class="divider-v"></div>
        <div class="status-item">Astro SSR · v5.x</div>
      </div>
      <div class="footer-links">
        <div class="status-item">
          <a
            href="https://github.com/Ascensian/pocketbase-astro-blog"
            target="_blank"
            style="color: #4a6a7c; text-decoration: none; letter-spacing: 0.1em; display: inline-flex; align-items: center; gap: 0.4em;"
          >
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="currentColor">
              <path d="M12 0C5.37 0 0 5.37 0 12c0 5.3 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61-.546-1.385-1.335-1.755-1.335-1.755-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23A11.52 11.52 0 0 1 12 5.803c1.02.005 2.047.138 3.006.404 2.29-1.552 3.297-1.23 3.297-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 21.795 24 17.295 24 12c0-6.63-5.37-12-12-12z"/>
            </svg>
            Journal de bord
          </a>
        </div>
        <div class="divider-v"></div>
        <div class="status-item">
          <a
            href="https://github.com/Ascensian/indexer-labs-uniswapV4"
            target="_blank"
            style="color: #4a6a7c; text-decoration: none; letter-spacing: 0.1em; display: inline-flex; align-items: center; gap: 0.4em;"
          >
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="currentColor">
              <path d="M12 0C5.37 0 0 5.37 0 12c0 5.3 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61-.546-1.385-1.335-1.755-1.335-1.755-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23A11.52 11.52 0 0 1 12 5.803c1.02.005 2.047.138 3.006.404 2.29-1.552 3.297-1.23 3.297-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 21.795 24 17.295 24 12c0-6.63-5.37-12-12-12z"/>
            </svg>
            Indexeur
          </a>
        </div>
      </div>
    </footer>
  </body>
</html>
