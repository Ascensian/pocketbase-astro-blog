---
import Layout from '../layouts/Layout.astro';
import { pb } from '../lib/pocketbase';

const ressources = await pb.collection('ressources').getFullList({
  sort: 'created',
});

function getFileUrl(record: any): string {
  return pb.files.getURL(record, record.file);
}
---

<Layout title="Ressources — Hugo GERARD">
  <section class="hero">
    <div class="hero-label">// ressources</div>
    <h1>Ressources</h1>
  </section>

  <section class="resources-grid">
    {ressources.map((r: any) => (
      <article class={`card card--${r.type}`}>
        <div class="card-header">
          <span class="card-type-badge">
            {r.type === 'pdf' ? (
              <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
                <polyline points="14 2 14 8 20 8"/>
                <line x1="16" y1="13" x2="8" y2="13"/>
                <line x1="16" y1="17" x2="8" y2="17"/>
                <polyline points="10 9 9 9 8 9"/>
              </svg>
            ) : (
              <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"/>
                <path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"/>
              </svg>
            )}
            {r.type}
          </span>
        </div>

        <div class="card-body">
          <h2 class="card-title">{r.title}</h2>
          {r.description && <p class="card-desc">{r.description}</p>}
        </div>

        <div class="card-footer">
          {r.type === 'pdf' && r.file ? (
            <a href={getFileUrl(r)} target="_blank" rel="noopener noreferrer" class="card-link card-link--pdf">
              <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/>
                <polyline points="7 10 12 15 17 10"/>
                <line x1="12" y1="15" x2="12" y2="3"/>
              </svg>
              Télécharger le PDF
            </a>
          ) : r.url ? (
            <a href={r.url} target="_blank" rel="noopener noreferrer" class="card-link card-link--url">
              <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/>
                <polyline points="15 3 21 3 21 9"/>
                <line x1="10" y1="14" x2="21" y2="3"/>
              </svg>
              Ouvrir le lien
            </a>
          ) : null}
        </div>
      </article>
    ))}
  </section>

  {ressources.length === 0 && (
    <div class="empty">
      <span class="empty-label">// aucune ressource disponible</span>
    </div>
  )}
</Layout>

<style>
  .hero {
    padding: 56px 32px 40px;
    border-bottom: 0.5px solid #1e2a35;
  }

  .hero-label {
    font-size: 11px;
    color: #4a6a7c;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    margin-bottom: 12px;
  }

  .hero h1 {
    font-size: 32px;
    font-weight: 800;
    color: #ffffff;
    letter-spacing: -0.02em;
    margin-bottom: 10px;
  }

  .hero-sub {
    font-size: 13px;
    color: #4a6a7c;
    letter-spacing: 0.02em;
  }

  .resources-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: 0;
    padding: 32px;
  }

  .card {
    border: 0.5px solid #1e2a35;
    padding: 28px;
    display: flex;
    flex-direction: column;
    gap: 16px;
    transition: border-color 0.2s, background 0.2s;
    margin: -0.25px;
  }

  .card:hover {
    border-color: #2e4a5a;
    background: #0d1219;
  }

  .card-header {
    display: flex;
    align-items: center;
  }

  .card-type-badge {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-size: 10px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    padding: 4px 10px;
    border-radius: 2px;
    font-weight: 600;
  }

  .card--pdf .card-type-badge {
    color: #e06c5a;
    background: rgba(224, 108, 90, 0.08);
    border: 0.5px solid rgba(224, 108, 90, 0.2);
  }

  .card--link .card-type-badge {
    color: #00e5a0;
    background: rgba(0, 229, 160, 0.08);
    border: 0.5px solid rgba(0, 229, 160, 0.2);
  }

  .card-body {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .card-title {
    font-size: 16px;
    font-weight: 600;
    color: #ffffff;
    letter-spacing: -0.01em;
    line-height: 1.3;
  }

  .card-desc {
    font-size: 12px;
    color: #4a6a7c;
    line-height: 1.7;
    letter-spacing: 0.02em;
  }

  .card-footer {
    margin-top: 4px;
  }

  .card-link {
    display: inline-flex;
    align-items: center;
    gap: 7px;
    font-size: 11px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    text-decoration: none;
    font-weight: 600;
    padding: 8px 14px;
    border-radius: 2px;
    transition: background 0.2s, color 0.2s;
  }

  .card-link--pdf {
    color: #e06c5a;
    border: 0.5px solid rgba(224, 108, 90, 0.3);
  }

  .card-link--pdf:hover {
    background: rgba(224, 108, 90, 0.1);
    border-color: rgba(224, 108, 90, 0.6);
  }

  .card-link--url {
    color: #00e5a0;
    border: 0.5px solid rgba(0, 229, 160, 0.3);
  }

  .card-link--url:hover {
    background: rgba(0, 229, 160, 0.08);
    border-color: rgba(0, 229, 160, 0.6);
  }

  .empty {
    padding: 80px 32px;
    text-align: center;
  }

  .empty-label {
    font-size: 12px;
    color: #2e4a5a;
    letter-spacing: 0.1em;
  }

  @media (max-width: 540px) {
    .hero {
      padding: 40px 16px 28px;
    }

    .hero h1 {
      font-size: 24px;
    }

    .resources-grid {
      padding: 16px;
      grid-template-columns: 1fr;
    }
  }
</style>
